# Chicago Crime Prediction — .gitignore
# ============================================================

# ── Data files ───────────────────────────────────────────
# Never commit raw or processed data to GitHub
data/
*.csv
*.parquet
*.json

# ── Model outputs ────────────────────────────────────────
# Trained model files can be very large
outputs/*.pth
outputs/*.keras
outputs/*.h5
outputs/*.pt

# ── Google Cloud credentials ─────────────────────────────
# IMPORTANT: never commit credentials or API keys
*.json
application_default_credentials.json
service_account*.json
*credentials*.json

# ── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ─────────────────────────────────
venv/
env/
.env
.venv
ENV/

# ── Jupyter notebooks checkpoints ───────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── VS Code ──────────────────────────────────────────────
.vscode/
*.code-workspace

# ── PySpark ──────────────────────────────────────────────
spark-warehouse/
metastore_db/
derby.log

# ── OS files ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# Logs 
*.log
logs/